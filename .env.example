# Copier ce fichier en .env et remplir les valeurs avant de lancer le projet.
# Ne jamais commiter le fichier .env (il est dans .gitignore).

# --- YouTube Data API v3 -----------------------------------------------------------
# Obtenir une cle sur : https://console.cloud.google.com/apis/credentials
# Activer l'API "YouTube Data API v3" dans le projet Google Cloud.
YOUTUBE_API_KEY=your_youtube_data_v3_api_key_here

# --- Groq API (classification rhetorique LLM) --------------------------------------
# Obtenir une cle sur : https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
